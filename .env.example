PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy/browser key fallback if you are not using publishable keys.
PUBLIC_SUPABASE_ANON_KEY=

# Optional fully local browser Auth testing: put these in `.env.development.local`.
# Remove that file when you want `pnpm dev` to use hosted Supabase from `.env.local`.
# PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# PUBLIC_SUPABASE_PUBLISHABLE_KEY=<PUBLISHABLE_KEY from `supabase status -o env`>
# SITE_URL=http://127.0.0.1:5173/app/

# Local scripts and GitHub Actions secrets. Never expose these in frontend code.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_TOKEN_ENCRYPTION_KEY=
SITE_URL=
