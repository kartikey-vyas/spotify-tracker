# Local Edge Function secrets. Copy this to `supabase/functions/.env`.
# `supabase start` loads `supabase/functions/.env` automatically.
SUPABASE_SECRET_KEY=

# Needed only when testing Spotify connect/callback locally.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_TOKEN_ENCRYPTION_KEY=
SITE_URL=http://127.0.0.1:5173/app/
