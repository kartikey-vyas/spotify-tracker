{
  "name": "spotify-history-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.scripts.json",
    "spotify:auth": "tsx scripts/spotify-auth.ts",
    "import:spotify-export": "tsx scripts/import-spotify-export.ts",
    "sync:recently-played": "tsx scripts/sync-recently-played.ts",
    "enrich:metadata": "tsx scripts/enrich-metadata.ts",
    "refresh:rollups": "tsx scripts/refresh-rollups.ts",
    "db:size": "tsx scripts/db-size.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.18.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.13.10",
    "svelte": "^5.20.2",
    "svelte-check": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
